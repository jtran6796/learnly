{
  "manifest_version": 3,
  "name": "Learnly",
  "version": "0.1.0",
  "description": "AI study buddy that turns whatever you're reading into questions.",
  "permissions": ["activeTab", "scripting", "sidePanel", "storage"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_title": "Learnly — generate study questions"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
